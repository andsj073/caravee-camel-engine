# Caravee Engine Agent
#
# Minimal image — only the Go binary.
# ~2000 lines of Go, open source, easy to audit.

FROM golang:1.22 AS build

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-s -w" \
    -o caravee-engine ./cmd/agent/

# ── Runtime: minimal alpine (curl needed for health checks) ───────────────
FROM alpine:3.19

RUN apk add --no-cache curl

COPY --from=build /build/caravee-engine /usr/local/bin/caravee-engine

RUN mkdir -p /data/routes

VOLUME /data

ENTRYPOINT ["caravee-engine"]
